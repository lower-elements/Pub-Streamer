# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/

# Config (contains user-specific paths and credentials)
config.ini

# Native CMake build cache — intermediate files only, not the final binaries.
# native/dist/ output is built locally or in CI and not committed to the repo.
native/**/build*/
native/**/CMakeFiles/
native/**/CMakeCache.txt
native/**/*.cmake
native/**/*.vcxproj
native/**/*.vcxproj.filters
native/**/*.sln
native/**/Makefile

